{
  "name": "khiw-portfolio-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ikkyu (khiw.dev) portfolio as a hybrid MCP App — standalone web + Claude Desktop MCP. Drill-down, explode, expand, cross-section tech-focus.",
  "scripts": {
    "build:ui": "cross-env INPUT=mcp-app.html vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:standalone": "cross-env INPUT=standalone.html vite build --outDir dist-standalone --emptyOutDir",
    "build": "npm run build:ui && npm run build:server",
    "build:all": "npm run build && npm run build:standalone",
    "serve": "tsx main.ts",
    "serve:stdio": "tsx main.ts --stdio",
    "dev": "vite",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
